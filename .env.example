# Copy this file to .env in the repo-demo-video-skill project root.
# Never commit your real .env file.

# Recommended: use one OpenAI API key for both professional script writing
# and OpenAI TTS voiceover. Replace the placeholder API key with your local key.
#
# The same OPENAI_API_KEY is used by:
# - professional demo narration writing via the Responses API
# - OpenAI TTS voiceover via the Audio Speech API
OPENAI_API_KEY=sk-your-api-key-here

# Optional professional script writer settings:
# SCRIPT_PROVIDER=openai enables LLM-written demo narration.
# Set SCRIPT_PROVIDER=template to force the deterministic fallback script.
SCRIPT_PROVIDER=openai
OPENAI_SCRIPT_MODEL=gpt-5.4-mini

# Optional shared fallback model setting:
# OPENAI_MODEL is used only if OPENAI_SCRIPT_MODEL is not set.
# OPENAI_MODEL=gpt-5.4-mini

# Optional OpenAI TTS settings:
# If OPENAI_API_KEY is set and TTS_PROVIDER is unset, full mode uses OpenAI TTS by default.
# Keep TTS_PROVIDER=openai for clarity, or set TTS_PROVIDER=mock to force no external TTS.
TTS_PROVIDER=openai
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
OPENAI_TTS_INSTRUCTIONS=Speak like a polished product demo narrator: clear, warm, concise, and confident.

# Fallback behavior:
# If OPENAI_API_KEY is not set, the CLI still runs with template script writing
# and mock voiceover mode.
#
# If TTS_PROVIDER is set to mock/none/off, or OPENAI_API_KEY is not set,
# the CLI only writes voiceover_script.txt and instructions.
# Mock voiceover fallback does not create voiceover.mp3.
